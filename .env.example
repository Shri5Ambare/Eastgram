# ───────────────────────── App ─────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────── Database ──────────────────────
# Postgres connection string used by Prisma
DATABASE_URL=postgresql://edugram:edugram@localhost:5432/edugram?schema=public

# ──────────────────────── Redis ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ───────────────────────── JWT ─────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_REFRESH_TTL=30d

# ──────────────────── Cloudflare R2 ────────────────────
# R2 is S3-compatible. Endpoint looks like https://<accountid>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=edugram-media
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.edugram.example.com
R2_PRESIGN_TTL=900

# ─────────────── Firebase Cloud Messaging ──────────────
# Path to the Firebase service-account JSON (admin SDK)
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Set to false to disable push notifications locally
FCM_ENABLED=false

# ─────────────────────── Throttle ──────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
